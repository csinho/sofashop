# Copie para .env na raiz do projeto (nunca commite o .env real).

# URL do projeto Supabase: Dashboard → Settings → API → Project URL
VITE_SUPABASE_URL=https://xxxx.supabase.co

# Chave pública ANON (publishable). Dashboard → Settings → API → anon public
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# NÃO coloque aqui a service_role — ela só em backend/CI com segredo, nunca no bundle do Vite.

# PWA / identidade na tela inicial (opcional; padrão: SofáShop)
# VITE_PWA_NAME=Minha Loja
# VITE_PWA_SHORT_NAME=Minha Loja
# VITE_PWA_DESCRIPTION=Catálogo e gestão da sua loja.
# Título da aba inteiro (opcional). Se vazio, usa «VITE_PWA_NAME» — Catálogo online
# VITE_PWA_DOCUMENT_TITLE=Minha Loja — Catálogo online
#
# Admin geral (todas as lojas), após rodar a migration 0009 no Supabase:
#   insert into public.platform_admins (user_id) values ('<seu-uuid em auth.users>'::uuid);
# Rota no app: /plataforma/lojas
